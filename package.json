{
  "name": "compression-files",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "test": "node --test",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "typecheck": "tsc --noEmit",
    "benchmark:generate": "node scripts/generate-benchmark-fixtures.mjs",
    "benchmark": "node scripts/benchmark-processing.mjs",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "file-type": "^21.0.0",
    "lucide-react": "^0.525.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.9.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
